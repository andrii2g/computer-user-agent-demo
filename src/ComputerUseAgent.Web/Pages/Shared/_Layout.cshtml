<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ComputerUseAgent.Demo</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ComputerUseAgent.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a asp-page="/Index" class="brand">ComputerUseAgent.Demo</a>
    </header>
    <main class="page-shell">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
